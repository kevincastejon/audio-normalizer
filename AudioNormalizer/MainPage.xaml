<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AudioNormalizer.MainPage"
             x:Name="HomePage"
             Title="Audio Normalizer">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto" Padding="16" RowSpacing="12">
        <Button Grid.Row="0"
                Text="Select folder"
                Clicked="OnPickFolderClicked"
                IsEnabled="{Binding IsNotNormalizing}" />

        <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto" ColumnSpacing="12">
            <Label Grid.Column="0"
                   Text="Output file name postfix"
                   VerticalOptions="Center" />
            <Entry Grid.Column="1"
                   Placeholder="(leaving this empty will overwrite input files)"
                   Text="{Binding OutputPostfix}"
                   IsEnabled="{Binding IsNotNormalizing}"
                   VerticalOptions="Center"
                   MinimumWidthRequest="50"/>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <Label Grid.Column="0"
                   Text="Output attenuation (dB)"
                   VerticalOptions="Center" />

            <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                <Button Text="-"
                        WidthRequest="40"
                        Clicked="OnOutputAttenuationMinusClicked"
                        IsEnabled="{Binding IsNotNormalizing}" />
                <Entry WidthRequest="90"
                       HorizontalTextAlignment="Center"
                       Keyboard="Numeric"
                       Text="{Binding OutputAttenuationText}"
                       TextChanged="OnOutputAttenuationTextChanged"
                       Unfocused="OnOutputAttenuationUnfocused"
                       IsEnabled="{Binding IsNotNormalizing}" />
                <Button Text="+"
                        WidthRequest="40"
                        Clicked="OnOutputAttenuationPlusClicked"
                        IsEnabled="{Binding IsNotNormalizing}" />
            </HorizontalStackLayout>
        </Grid>

        <HorizontalStackLayout Grid.Row="3" Spacing="12" IsVisible="{Binding HasItems}">
            <Button Text="Select all" Clicked="OnSelectAllClicked" IsEnabled="{Binding IsNotNormalizing}" />
            <Button Text="Clear all" Clicked="OnClearAllClicked" IsEnabled="{Binding IsNotNormalizing}" />
        </HorizontalStackLayout>

        <HorizontalStackLayout Grid.Row="4" Spacing="12" IsVisible="{Binding IsNormalizing}">
            <Button Text="Cancel" Clicked="OnCancelClicked" />
            <Label Text="Normalizing..." VerticalOptions="Center" />
        </HorizontalStackLayout>

        <Label Grid.Row="5" Text="{Binding SelectedFilesText}" VerticalOptions="Center" IsVisible="{Binding ShowSelectedCount}"/>

        <Grid Grid.Row="6">
            <CollectionView ItemsSource="{Binding AudioFiles}" IsVisible="{Binding HasItems}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" Padding="6" ColumnSpacing="10">
                            <CheckBox IsVisible="{Binding BindingContext.IsNotNormalizing, Source={x:Reference HomePage}}"
                                      Grid.Column="0"
                                      IsChecked="{Binding IsChecked}"
                                      VerticalOptions="Center" />

                            <Grid Grid.Column="1" WidthRequest="24" HeightRequest="24" VerticalOptions="Center" HorizontalOptions="Center">
                                <ActivityIndicator IsRunning="{Binding IsProcessing}"
                                                   IsVisible="{Binding IsProcessing}"
                                                   VerticalOptions="Center"
                                                   HorizontalOptions="Center" />

                                <Path IsVisible="{Binding IsSucceeded}"
                                      Data="M2,12 L9,19 L22,4"
                                      Stroke="Green"
                                      StrokeThickness="2.5"
                                      StrokeLineCap="Round"
                                      StrokeLineJoin="Round"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center" />

                                <Path IsVisible="{Binding IsFailed}"
                                      Data="M5,5 L19,19 M19,5 L5,19"
                                      Stroke="Red"
                                      StrokeThickness="2.5"
                                      StrokeLineCap="Round"
                                      StrokeLineJoin="Round"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center" />
                            </Grid>

                            <Label Grid.Column="2"
                                   ToolTipProperties.Text="{Binding FullPath}"
                                   Text="{Binding FileName}"
                                   LineBreakMode="CharacterWrap"
                                   VerticalOptions="Center" />

                            <Border Grid.Column="3"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    StrokeThickness="1"
                                    Stroke="#4A4A4A"
                                    Background="#2A2A2A"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="0"
                                    IsVisible="{Binding BindingContext.IsNotNormalizing, Source={x:Reference HomePage}}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPlaySourceTapped" />
                                </Border.GestureRecognizers>

                                <Grid WidthRequest="20" HeightRequest="20"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center">
                                    <Path IsVisible="{Binding IsNotPlayingSource}"
                                          Data="M8,5 L19,12 L8,19 Z"
                                          Fill="White"
                                          Aspect="Uniform"
                                          HorizontalOptions="Fill"
                                          VerticalOptions="Fill" />

                                    <Path IsVisible="{Binding IsPlayingSource}"
                                          Data="M8,8 H16 V16 H8 Z"
                                          Fill="White"
                                          Aspect="Uniform"
                                          HorizontalOptions="Fill"
                                          VerticalOptions="Fill" />
                                </Grid>
                            </Border>

                            <Border Grid.Column="4"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    StrokeThickness="1"
                                    Stroke="#4A4A4A"
                                    Background="#2A2A2A"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="0"
                                    IsVisible="{Binding BindingContext.IsNotNormalizing, Source={x:Reference HomePage}}"
                                    InputTransparent="{Binding IsPreviewGenerating}"
                                    Opacity="{Binding PreviewButtonOpacity}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPreviewTapped" />
                                </Border.GestureRecognizers>

                                <Grid WidthRequest="20" HeightRequest="20"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center">
                                    <ActivityIndicator IsRunning="{Binding IsPreviewGenerating}"
                                                       IsVisible="{Binding IsPreviewGenerating}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />

                                    <Path IsVisible="{Binding IsPreviewEyeVisible}"
                                          Data="M2,12 C5,6 19,6 22,12 C19,18 5,18 2,12 Z M12,9 A3,3 0 1 0 12,15 A3,3 0 1 0 12,9 Z"
                                          Stroke="White"
                                          StrokeThickness="1.8"
                                          StrokeLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Aspect="Uniform"
                                          HorizontalOptions="Fill"
                                          VerticalOptions="Fill" />

                                    <Path IsVisible="{Binding IsPreviewStopVisible}"
                                          Data="M8,8 H16 V16 H8 Z"
                                          Fill="White"
                                          Aspect="Uniform"
                                          HorizontalOptions="Fill"
                                          VerticalOptions="Fill" />
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="{Binding NoFilesMessage}"
                   IsVisible="{Binding ShowNoFilesMessage}"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />
        </Grid>

        <Button Grid.Row="7"
                Text="Normalize"
                IsEnabled="{Binding IsNotNormalizing}"
                IsVisible="{Binding HasItems}"
                Clicked="OnNormalizeClicked" />
    </Grid>

</ContentPage>